PORT=5001
NODE_ENV=development
STRICT_PRODUCTION_ENV=false

# Local dev can omit DATABASE_URL to use SQLite.
# Production must set PostgreSQL DATABASE_URL.
DATABASE_URL=

# Required in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
ADMIN_SUPPORT_PASSWORD=change_this_admin_password
ADMIN_EMAIL=admin@example.com
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
FIREBASE_PROJECT_ID=your_firebase_project_id

# Email via Resend
RESEND_API_KEY=
EMAIL_FROM=BookAm <noreply@bookam.business>

# Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Real push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Production media storage
CLOUDINARY_URL=
S3_BUCKET=
R2_BUCKET=

# Launch operations
SENTRY_DSN=
DB_BACKUPS_ENABLED=false
DATABASE_BACKUP_URL=
RENDER_POSTGRES_BACKUPS=false
